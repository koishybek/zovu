  "info": {
    "title": "Zovu API",
    "description": "C2C-маркетплейс услуг — REST /v1. Source of truth: docs/04-api.md",
    "version": "0.2.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RequestOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+77012345678",
            "description": "Номер КЗ (нормализуется на сервере)"
          }
        },
        "required": [
          "phone"
        ]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+77012345678"
          },
          "code": {
            "type": "string",
            "example": "1111",
            "description": "OTP из SMS (dev — всегда 1111)"
          }
        },
        "required": [
          "phone",
          "code"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refresh_token": {
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ]
      },
      "UpdateMeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "dob": {
            "type": "string",
            "example": "1998-05-12"
          },
          "lang": {
            "type": "string",
            "enum": [
              "ru",
              "kk"
            ]
          }
        }
      },
      "SwitchRoleDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "client",
              "specialist"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "RegisterDeviceDto": {
        "type": "object",
        "properties": {
          "fcmToken": {
            "type": "string"
          },
          "platform": {
            "type": "string",
            "example": "web"
          }
        },
        "required": [
          "fcmToken",
          "platform"
        ]
      },
      "SpecialistProfileDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "dob": {
            "type": "string",
            "example": "1990-01-01"
          },
          "mainCategoryId": {
            "type": "string"
          },
          "categoryIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "about": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "mainCategoryId"
        ]
      },
      "SuggestCategoryDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
}