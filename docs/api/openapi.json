  "info": {
    "title": "Zovu API",
    "description": "C2C-маркетплейс услуг — REST /v1. Source of truth: docs/04-api.md",
    "version": "0.2.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RequestOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+77012345678",
            "description": "Номер КЗ (нормализуется на сервере)"
          }
        },
        "required": [
          "phone"
        ]
      },
      "VerifyOtpDto": {
        "type": "object",
        "properties": {
          "phone": {
            "type": "string",
            "example": "+77012345678"
          },
          "code": {
            "type": "string",
            "example": "1111",
            "description": "OTP из SMS (dev — всегда 1111)"
          }
        },
        "required": [
          "phone",
          "code"
        ]
      },
      "RefreshDto": {
        "type": "object",
        "properties": {
          "refresh_token": {
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ]
      },
      "UpdateMeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "dob": {
            "type": "string",
            "example": "1998-05-12"
          },
          "lang": {
            "type": "string",
            "enum": [
              "ru",
              "kk"
            ]
          }
        }
      },
      "SwitchRoleDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "client",
              "specialist"
            ]
          }
        },
        "required": [
          "role"
        ]
      },
      "RegisterDeviceDto": {
        "type": "object",
        "properties": {
          "fcmToken": {
            "type": "string"
          },
          "platform": {
            "type": "string",
            "example": "web"
          }
        },
        "required": [
          "fcmToken",
          "platform"
        ]
      },
      "SpecialistProfileDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "dob": {
            "type": "string",
            "example": "1990-01-01"
          },
          "mainCategoryId": {
            "type": "string"
          },
          "categoryIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "about": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "mainCategoryId"
        ]
      },
      "SuggestCategoryDto": {
        "type": "object",
        "properties": {}
      },
      "OrderFiltersDto": {
        "type": "object",
        "properties": {
          "certifiedOnly": {
            "type": "boolean"
          },
          "minRating": {
            "type": "number"
          },
          "minOrders": {
            "type": "number"
          },
          "maxDistanceKm": {
            "type": "number"
          }
        }
      },
      "CreateOrderDto": {
        "type": "object",
        "properties": {
          "categoryId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "photos": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "budget": {
            "type": "number"
          },
          "address": {
            "type": "string"
          },
          "lat": {
            "type": "number"
          },
          "lng": {
            "type": "number"
          },
          "filters": {
            "$ref": "#/components/schemas/OrderFiltersDto"
          }
        },
        "required": [
          "categoryId",
          "title",
          "description",
          "budget",
          "address"
        ]
      },
      "CreateBidDto": {
        "type": "object",
        "properties": {
          "price": {
            "type": "number",
            "description": "Цена специалиста (предзаполнена бюджетом заказа)"
          },
          "availability": {
            "type": "string",
            "description": "Когда готов приступить",
            "enum": [
              "today",
              "tomorrow",
              "this_week"
            ]
          },
          "hasMaterials": {
            "type": "boolean",
            "description": "Есть материалы/инструмент"
          },
          "comment": {
            "type": "string",
            "description": "Короткий комментарий/питч (≤200)"
          }
        },
        "required": [
          "price"
        ]
      },
      "TopupDto": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "example": 2000
          },
          "method": {
            "type": "string",
            "enum": [
              "kaspi",
              "card"
            ]
          }
        },
        "required": [
          "amount",
          "method"
        ]
      },
      "ReviewDto": {
        "type": "object",
        "properties": {
          "stars": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "stars"
        ]
      },
      "ComplaintDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          }
        },
        "required": [
          "reason"
        ]
      },
      "ReasonDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      },
      "DiplomaDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "approve",
              "reject",
              "revoke"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "ReplyDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      },
      "UserActionDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          },
          "action": {
            "type": "string",
            "enum": [
              "warn",
              "block",
              "unblock"
            ]
          }
        },
        "required": [
          "action"
        ]
      },
      "CreateTicketDto": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "Заказ",
              "Оплата",
              "Жалоба",
              "Верификация",
              "Иное"
            ]
          },
          "text": {
            "type": "string"
          },
          "orderId": {
            "type": "string"
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "category",
          "text"
        ]
      },
      "MessageDto": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "attachments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "text"
        ]
      },
      "RateDto": {
        "type": "object",
        "properties": {
          "rating": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          }
        },
        "required": [
          "rating"
        ]
      }
    }
  }
}