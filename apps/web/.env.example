# apps/web — фронтовые env (Vite, префикс VITE_ вшивается в бандл на build).

# Origin бэкенда для ПРОД-сборки (Vercel). В dev НЕ задавать —
# используется относительный путь через vite dev-proxy (vite.config.ts → localhost:3000).
# Пример: VITE_API_URL=https://zovu-api.up.railway.app
VITE_API_URL=

# Показать «Быстрый вход (demo)» на Welcome в ПРОД-сборке (для показа клиенту).
# В dev быстрый вход и так виден. Для реального прода не задавать.
VITE_DEMO=
