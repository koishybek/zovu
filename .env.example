# ==== Zovu API ====
# Скопируй в .env и подставь значения. Ни один прод-ключ для демо не нужен.

# База данных
# Docker (docker-compose.yml):  postgresql://zovu:zovu_dev@localhost:5434/zovu
# Локальный PG без Docker (ADR-005): поставь свой порт/креды
DATABASE_URL=postgresql://zovu:zovu_dev@localhost:5434/zovu

# JWT (НФ-05: access 15 мин, refresh 30 дней, ротация)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Админка: статический токен (мини-админка, без пользователей)
ADMIN_TOKEN=dev_admin_token_change_me

# Бизнес-правила
ORDER_COMMISSION_PCT=5            # ADR-001: комиссия от цены принятого отклика, можно 0
SUBSCRIPTION_PRICE=100            # ₸/день
TZ=Asia/Almaty                    # кроны считаются в этом поясе

# Dev-удобства
AUTO_APPROVE_VERIFICATION=true    # одобрение верификации через ~5 сек (S-07)
DEV_OTP_CODE=1111                 # OTP в dev всегда 1111 + печать в лог

# Провайдеры (все за интерфейсами, docs/08-integrations.md)
SMS_PROVIDER=dev                  # dev | mobizon(заглушка)
PAYMENT_PROVIDER=dev              # dev | kaspi(заглушка)
PUSH_PROVIDER=dev                 # dev (Notification + WS) | fcm(заглушка)
MODERATOR_PROVIDER=dev            # dev (стоп-словарь RU/KZ) | anthropic(заглушка)
STORAGE_PROVIDER=minio            # minio | local (фоллбэк без Docker, ADR-005) | s3(заглушка)

# MinIO / S3 (при STORAGE_PROVIDER=minio)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=zovu
MINIO_SECRET_KEY=zovu_dev_secret
MINIO_BUCKET_PUBLIC=zovu-public   # фото заказов
MINIO_BUCKET_PRIVATE=zovu-private # документы верификации/дипломы (НФ-09)

# Storage: локальный фоллбэк (при STORAGE_PROVIDER=local)
LOCAL_STORAGE_DIR=.storage

# API
PORT=3000
